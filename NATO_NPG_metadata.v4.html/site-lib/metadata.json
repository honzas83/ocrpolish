 of nuclear weapons during times of tension or hostilities.NPG/D(73)15Nuclear Planning Group Follow-On Use Work Programme Status of Work in Progress as of 1st October, 1973This report by the Permanent Representatives of the Nuclear Planning Group provides an update on the progress of the study regarding the follow-on tactical use of nuclear weapons.","aliases":[],"inlineTags":[],"frontmatterTags":[],"headers":[],"links":[],"author":"","coverImageURL":"","fullURL":"content.html","pathToRoot":".","attachments":[],"createdTime":1778156341126,"modifiedTime":1778156341126,"sourceSize":564,"sourcePath":"CONTENT.base","exportPath":"content.html","showInTree":true,"treeOrder":15,"backlinks":[],"type":"bases"}},"fileInfo":{"npg-nuclear-planning-group/1-npg-nuclear-planning-group/1973/pdf/npg-d(73)10_eng.pdf":{"createdTime":1778060563493,"modifiedTime":1778060563748,"sourceSize":999180,"sourcePath":"NPG - Nuclear Planning Group/1 NPG - Nuclear Planning Group/1973/pdf/NPG-D(73)10_ENG.PDF","exportPath":"npg-nuclear-planning-group/1-npg-nuclear-planning-group/1973/pdf/npg-d(73)10_eng.pdf","showInTree":true,"treeOrder":0,"backlinks":[],"type":"other","data":null},"npg-nuclear-planning-group/1-npg-nuclear-planning-group/1973/pdf/npg-d(73)10_eng.html":{"createdTime":1778060563493,"modifiedTime":1778060563748,"sourceSize":999180,"sourcePath":"NPG - Nuclear Planning Group/1 NPG - Nuclear Planning Group/1973/pdf/NPG-D(73)10_ENG.PDF","exportPath":"npg-nuclear-planning-group/1-npg-nuclear-planning-group/1973/pdf/npg-d(73)10_eng.html","showInTree":true,"treeOrder":4,"backlinks":["npg-nuclear-planning-group/1-npg-nuclear-planning-group/1973/npg-d(73)10_eng.html"],"type":"attachment","data":null},"npg-nuclear-planning-group/1-npg-nuclear-planning-group/1973/pdf/npg-d(73)11_eng.pdf":{"createdTime":1778060534814,"modifiedTime":1778060535154,"sourceSize":680604,"sourcePath":"NPG - Nuclear Planning Group/1 NPG - Nuclear Planning Group/1973/pdf/NPG-D(73)11_ENG.PDF","exportPath":"npg-nuclear-pla